{
  "name": "telos",
  "version": "0.1.0",
  "description": "Hierarchical goal and task management with value-based prioritization",
  "main": "src/cli.js",
  "bin": {
    "telos": "./src/cli.js"
  },
  "scripts": {
    "init": "node src/cli.js init",
    "start": "node server.js",
    "serve": "node src/server.js",
    "api": "node api-server.js",
    "test": "node src/cli.js list",
    "postinstall": "cd node_modules/better-sqlite3 && PATH=/home/linuxbrew/.linuxbrew/bin:$PATH node-gyp rebuild 2>/dev/null || true"
  },
  "keywords": [
    "goal",
    "task",
    "management",
    "prioritization",
    "value",
    "roi"
  ],
  "author": "Atlas (MacroHard)",
  "license": "PROPRIETARY",
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "commander": "^12.1.0",
    "express": "4.22.1",
    "jsonwebtoken": "9.0.3"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  },
  "engines": {
    "node": ">=25.0.0"
  }
}
